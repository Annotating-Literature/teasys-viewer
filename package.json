{
	"name": "teasys-viewer",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "npm run build && rsync -avz --exclude='node_modules' --exclude='.git' --exclude='data' . nicolai@nicolai.lol:/var/www/teasys/ && ssh nicolai@nicolai.lol 'pm2 restart teasys'"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bcryptjs": "^2.4.6",
		"@types/better-sqlite3": "^7.6.13",
		"@types/marked": "^5.0.2",
		"@types/uuid": "^10.0.0",
		"autoprefixer": "^10.4.27",
		"marked": "^17.0.3",
		"postcss": "^8.5.6",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"uuid": "^13.0.0",
		"vite": "^7.3.1",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@fontsource/eb-garamond": "^5.2.7",
		"@fontsource/gentium-plus": "^5.2.7",
		"@fontsource/goudy-bookletter-1911": "^5.2.8",
		"@fontsource/sorts-mill-goudy": "^5.2.8",
		"@types/dompurify": "^3.0.5",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.6.2",
		"dompurify": "^3.3.1",
		"isomorphic-dompurify": "^3.0.0"
	}
}